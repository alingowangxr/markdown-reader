{
  "manifest_version": 3,
  "name": "Markdown Reader Overlay",
  "version": "1.0.0",
  "description": "Read webpages in markdown overlay mode without breaking browser history.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open Markdown Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "overlay.css",
        "libs/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}